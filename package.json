{
  "name": "@greyw0rks/proofleger",
  "version": "0.4.0",
  "description": "A Web3 proof and identity ledger",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stacks",
    "bitcoin",
    "web3",
    "proof",
    "identity",
    "ledger"
  ],
  "author": "greyw0rks",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/greyw0rks/proofleger.git"
  },
  "bugs": {
    "url": "https://github.com/greyw0rks/proofleger/issues"
  },
  "homepage": "https://github.com/greyw0rks/proofleger#readme",
  "dependencies": {
    "@stacks/auth": "^7.3.1",
    "@stacks/connect": "^8.2.5",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.3.1",
    "@stacks/wallet-sdk": "^7.2.0",
    "bip39": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
